## Electron Desktop - Firebase (Cliente Web SDK)
## Crea un proyecto en Firebase, habilita Firestore y copia estas credenciales.
FIREBASE_API_KEY="REEMPLAZAR"
FIREBASE_AUTH_DOMAIN="REEMPLAZAR"
FIREBASE_PROJECT_ID="REEMPLAZAR"
## Opcional: solo si activó Firebase Storage (plan Blaze). Sin esto, las fotos de entrega
## se guardan en historial como referencia textual o imagen pequeña (≤ 200 KB).
FIREBASE_STORAGE_BUCKET="REEMPLAZAR"
FIREBASE_MESSAGING_SENDER_ID="REEMPLAZAR"
FIREBASE_APP_ID="REEMPLAZAR"

## (Opcional) Para scripts de seed usando Admin SDK (recomendado)
## Ruta a un JSON de cuenta de servicio descargado desde Firebase Console.
FIREBASE_SERVICE_ACCOUNT_PATH="C:/ruta/a/serviceAccountKey.json"

## App
APP_NAME="Sistema de Envíos - GLS"
APP_ENV="development"

## Cotización por defecto en registro (opcional; edita también `src/config/app.config.js`)
# COT_MONEDA_DEFAULT="PEN"
# COT_DISTANCIA_KM="560"
# COT_TARIFA_KG="2.5"
# COT_TARIFA_M3="180"
# COT_TARIFA_KM="1.2"
# COT_SEGURO_PCT="0"

